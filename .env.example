# agent-toolbox.ai API — environment variables
# Copy to .env for local development

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Admin dashboard
ADMIN_API_KEY=               # Required to access /admin/* routes

# ── Solana Payments (required for paid tier) ──────────────────────────────────
# Your service wallet public key — agents send SOL here to buy credits
SOL_SERVICE_WALLET=

# Solana RPC endpoint. Public endpoint is rate-limited; use Helius for production:
# https://helius.dev (free: 100k requests/day)
SOL_RPC_URL=https://api.mainnet-beta.solana.com

# ── Redis (optional — falls back to in-memory) ────────────────────────────────
# Required for credit state to survive restarts and across multiple instances
REDIS_URL=redis://localhost:6379

# ── NLI / Hallucination Detection (optional) ──────────────────────────────────
# Vectara HHEM API key for natural language factual consistency checks
# Free tier: https://vectara.com
VECTARA_API_KEY=

# ── Context Distiller (optional) ─────────────────────────────────────────────
# URL of a LLMLingua-2 compatible endpoint for advanced compression
# If unset, uses the built-in TF-IDF importance scorer
LLMLINGUA_URL=
