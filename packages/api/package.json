{
  "name": "@agentoolbox/api",
  "version": "0.1.0",
  "description": "Agentoolbox REST API server",
  "homepage": "https://agent-toolbox.ai",
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "node --watch --import tsx/esm src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@agentoolbox/agent": "workspace:*",
    "@agentoolbox/compliance": "workspace:*",
    "@agentoolbox/core": "workspace:*",
    "@agentoolbox/finance": "workspace:*",
    "@agentoolbox/firewall": "workspace:*",
    "@agentoolbox/health": "workspace:*",
    "@agentoolbox/infra": "workspace:*",
    "@agentoolbox/legal": "workspace:*",
    "@agentoolbox/payments": "workspace:*",
    "@agentoolbox/privacy": "workspace:*",
    "@agentoolbox/validator": "workspace:*",
    "hono": "^4.5.0",
    "ioredis": "^5.4.0",
    "zod": "^3.23.0",
    "@hono/zod-validator": "^0.4.0",
    "@hono/node-server": "^1.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
