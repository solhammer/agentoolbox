{
  "name": "@agentoolbox/identity",
  "version": "0.1.0",
  "private": true,
  "description": "Deterministic, offline validation of structured identifiers (IBAN, ABA, SWIFT BIC, credit card, EIN, VAT EU, VIN, NPI, SSN, ETH, SOL) via checksums and format rules",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": { ".": { "import": "./dist/index.js", "types": "./dist/index.d.ts" } },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --exclude '**/*.integration.test.*'",
    "test:watch": "vitest --exclude '**/*.integration.test.*'",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": { "typescript": "^5.5.0", "vitest": "^2.0.0", "@types/node": "^22.0.0" }
}
