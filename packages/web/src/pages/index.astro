    <script is:inline>
      document.addEventListener('click', (e) => {
        // Let anchor clicks navigate normally (e.g. "More \u2192" tool page links)
        // But still allow [data-close] anchors to close dialogs
        if (e.target.closest('a[href]') && !e.target.closest('[data-close]')) return;
        const opener = e.target.closest('[data-modal]');
        if (opener) {
          const dlg = document.getElementById('modal-' + opener.getAttribute('data-modal'));
          if (dlg && typeof dlg.showModal === 'function') dlg.showModal();
          return;
        }
        const closer = e.target.closest('[data-close]');
        if (closer) {
          const d = closer.closest('dialog');
          if (d) d.close();
          return;
        }
        if (e.target.tagName === 'DIALOG') e.target.close();
      });
    </script>
