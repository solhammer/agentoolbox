---
import { features, securityTools, financeTools, safetyTools, platformTools, dataTools, allTools, icons } from '../data/tools';

const githubUrl = 'https://github.com/solhammer/agentoolbox';

const stats = [
  { value: '19.7%', label: 'of AI-generated packages are hallucinated', source: 'USENIX 2025' },
  { value: '\u20ac20M', label: 'max GDPR fine for a single data breach', source: 'GDPR Art. 83' },
  { value: '$440k', label: 'lost by one agent from a single decimal error', source: 'Lobstar 2026' },
];

const curlExample = `curl -X POST https://api.agent-toolbox.ai/v1/validate/imports \\\\
  -H "Content-Type: application/json" \\\\
  -d '{
    "language": "python",
    "code": "import numpy\\\\nfrom superlogger import magic_log\\\\nimport pandas"
  }'`;

const jsonResponse = `{
  "language": "python",
  "valid": [
    { "name": "numpy", "status": "valid", "registry": "pypi" },
    { "name": "pandas", "status": "valid", "registry": "pypi" }
  ],
  "hallucinated": [
    { "name": "superlogger", "status": "hallucinated", "evidence": "Not found on PyPI" }
  ],
  "verdict": "BLOCK",
  "totalImports": 3,
  "hallucinationRate": 0.33,
  "latencyMs": 142
}`;

const piiCurl = `curl -X POST https://api.agent-toolbox.ai/v1/scan/pii \\\\
  -H "Content-Type: application/json" \\\\
  -d '{
    "text": "Patient SSN 219-09-9999, card 4111 1111 1111 1111"
  }'`;

const piiResponse = `{
  "verdict": "BLOCK",
  "categories": ["PII", "PCI"],
  "totalFindings": 2,
  "redactedText": "Patient SSN [REDACTED_US_SSN], card [REDACTED_CREDIT_CARD]",
  "certificate": "sha256:5f691771..."
}`;

const mcpConfig = `{
  "mcpServers": {
    "agentoolbox": {
      "command": "npx",
      "args": ["-y", "agentoolbox-mcp"]
    }
  }
}`;

const mcpClients = [
  { label: 'Claude Desktop', file: '~/Library/Application Support/Claude/claude_desktop_config.json' },
  { label: 'Cursor', file: '~/.cursor/mcp.json' },
  { label: 'Warp', file: '~/.warp/mcp.json' },
  { label: 'VS Code (Cline/Continue)', file: '.vscode/mcp.json' },
];

const mcpTools = [
  'validate_imports', 'verify_output', 'distill_context',
  'scan_secrets', 'scan_injection', 'count_tokens', 'scan_vulnerabilities', 'scan_pii',
  'finance_units', 'finance_price', 'finance_symbol', 'finance_token_risk',
  'finance_slippage', 'finance_order_risk', 'finance_position_check',
  'screen_sanctions', 'rx_check',
  'check_tool_args', 'check_infra_plan', 'check_citation', 'compute_deadline',
  'validate_identifier', 'validate_schema', 'scan_sql',
  'scan_command', 'scan_url',
];
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="The quality layer every AI agent needs. Catch hallucinated packages, block bad outputs, redact PII/PHI/PCI, screen sanctions, validate tool arguments, gate infra changes, and guard trades \u2014 26 agent-callable APIs, pay per call in SOL."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <title>agent-toolbox.ai \u2014 The quality layer every AI agent needs</title>
    <style is:global>
      dialog.atb-modal {
        margin: auto;
        border: none;
        background: transparent;
        padding: 0;
        max-height: 90vh;
        color: white;
      }
      dialog.atb-modal::backdrop {
        background: rgba(1, 4, 9, 0.72);
        backdrop-filter: blur(3px);
      }
      dialog.atb-modal[open] {
        animation: atb-pop 0.16s ease-out;
      }
      @keyframes atb-pop {
        from { opacity: 0; transform: translateY(8px); }
        to { opacity: 1; transform: translateY(0); }
      }
    </style>
  </head>
  <body class="bg-surface text-white antialiased" style="font-family: 'Inter', system-ui, sans-serif;">
    <!-- NAV -->
    <header class="sticky top-0 z-40 border-b border-surface-border bg-surface/80 backdrop-blur">
      <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
        <a href="#top" class="flex items-center gap-2 font-mono text-lg font-semibold tracking-tight">
          <span class="inline-block h-2.5 w-2.5 rounded-full bg-brand"></span>
          <span>agent-toolbox<span class="text-brand">.ai</span></span>
        </a>
        <div class="flex items-center gap-3">
          <a href="#privacy-firewall" class="hidden text-sm font-medium text-[#8b949e] transition hover:text-white sm:inline">PII Firewall</a>
          <a href="#pricing" class="hidden text-sm font-medium text-[#8b949e] transition hover:text-white sm:inline">Pricing</a>
          <a href="/docs" class="hidden text-sm font-medium text-[#8b949e] transition hover:text-white sm:inline">Docs</a>
          <a href="/blog" class="hidden text-sm font-medium text-[#8b949e] transition hover:text-white sm:inline">Blog</a>
          <a
            href={githubUrl}
            class="inline-flex items-center gap-2 rounded-md border border-surface-border px-3 py-1.5 text-sm font-medium text-[#8b949e] transition hover:border-brand hover:text-white"
          >
            <svg viewBox="0 0 16 16" width="18" height="18" fill="currentColor" aria-hidden="true">
              <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"></path>
            </svg>
            GitHub
          </a>
        </div>
      </nav>
    </header>

    <main id="top">
      <!-- HERO -->
      <section class="relative overflow-hidden">
        <div
          class="pointer-events-none absolute inset-0 opacity-40"
          style="background: radial-gradient(600px circle at 50% 0%, rgba(0,212,170,0.15), transparent 70%);"
        >
        </div>
        <div class="relative mx-auto max-w-6xl px-6 py-24 text-center sm:py-32">
          <span
            class="inline-flex items-center rounded-full border border-brand/30 bg-brand/10 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-brand"
          >
            AI Agent Infrastructure
          </span>
          <h1 class="mx-auto mt-6 max-w-3xl text-4xl font-extrabold leading-tight tracking-tight sm:text-6xl">
            The quality layer every<br class="hidden sm:block" />
            AI agent needs
          </h1>
          <p class="mx-auto mt-6 max-w-2xl text-lg text-[#8b949e] sm:text-xl">
            Catch hallucinations. Block injections. Redact PII. Screen sanctions. Guard trades.
            <span class="text-white">26 tools. One platform. Pay per call in SOL.</span>
          </p>
          <div class="mt-10 flex flex-col items-center justify-center gap-3 sm:flex-row">
            <a
              href="#privacy-firewall"
              class="inline-flex w-full items-center justify-center rounded-lg bg-brand px-6 py-3 font-semibold text-surface transition hover:bg-brand-dark sm:w-auto"
            >
              Meet the PII Firewall
            </a>
            <a
              href={githubUrl}
              class="inline-flex w-full items-center justify-center rounded-lg border border-surface-border bg-surface-card px-6 py-3 font-semibold text-white transition hover:border-brand sm:w-auto"
            >
              View on GitHub
            </a>
          </div>
          <div class="mt-10 flex justify-center">
            <span
              class="inline-flex items-center gap-2 rounded-full border border-surface-border bg-surface-card px-4 py-1.5 font-mono text-sm text-[#8b949e]"
            >
              <span class="relative flex h-2.5 w-2.5">
                <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-brand opacity-75"></span>
                <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-brand"></span>
              </span>
              API Online \u00b7 &lt;200ms avg
            </span>
          </div>
        </div>
      </section>

      <!-- STATS BAR -->
      <section class="mx-auto max-w-6xl px-6 pb-12">
        <div class="grid grid-cols-1 gap-px overflow-hidden rounded-xl border border-surface-border bg-surface-border sm:grid-cols-3">
          {
            stats.map((stat) => (
              <div class="bg-surface-card p-8 text-center">
                <div class="font-mono text-4xl font-bold text-brand">{stat.value}</div>
                <p class="mt-2 text-sm text-[#8b949e]">{stat.label}</p>
                {stat.source && (
                  <p class="mt-1 text-xs font-medium uppercase tracking-wider text-[#6e7681]">{stat.source}</p>
                )}
              </div>
            ))
          }
        </div>
      </section>

      <!-- FEATURED: PII FIREWALL -->
      <section id="privacy-firewall" class="mx-auto max-w-6xl px-6 py-10">
        <div class="relative overflow-hidden rounded-2xl border border-brand/40 bg-surface-card p-8 sm:p-10">
          <div class="pointer-events-none absolute inset-0 opacity-60" style="background: radial-gradient(500px circle at 100% 0%, rgba(0,212,170,0.12), transparent 60%);"></div>
          <div class="relative grid grid-cols-1 items-start gap-8 lg:grid-cols-2">
            <div>
              <span class="inline-flex items-center gap-2 rounded-full border border-brand/40 bg-brand/10 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-brand">
                <span class="h-1.5 w-1.5 rounded-full bg-brand"></span> New \u00b7 Privacy
              </span>
              <h2 class="mt-5 text-3xl font-bold tracking-tight sm:text-4xl">
                Stop your agent from leaking regulated data
              </h2>
              <p class="mt-4 text-[#8b949e]">
                Agents write logs, file tickets, call third-party APIs, and store transcripts \u2014 and any of those can leak a customer's SSN, a card number, or a medical record. <span class="text-white">One unguarded egress is a reportable breach.</span> The PII / PHI / PCI Firewall is the deterministic gate your agent calls <span class="text-white">before</span> text crosses the boundary.
              </p>
              <ul class="mt-6 space-y-2 text-sm text-[#8b949e]">
                <li class="flex gap-2"><span class="text-brand">\u2713</span> Checksum-validated: cards (Luhn), IBANs (ISO-7064), UK NHS (mod-11), SIN \u2014 plus SSN, email, phone, IP</li>
                <li class="flex gap-2"><span class="text-brand">\u2713</span> PASS / FLAG / BLOCK, a redacted copy of the text, and a signed SHA-256 certificate</li>
                <li class="flex gap-2"><span class="text-brand">\u2713</span> block / flag / audit modes \u00b7 jurisdiction &amp; type policy \u00b7 nothing stored, raw values never returned \u00b7 &lt;20ms</li>
              </ul>
              <div class="mt-7 flex flex-wrap gap-3">
                <button
                  type="button"
                  data-modal="scan-pii"
                  class="inline-flex items-center justify-center rounded-lg bg-brand px-5 py-2.5 font-semibold text-surface transition hover:bg-brand-dark"
                >
                  Explore capabilities &amp; use cases \u2192
                </button>
                <a
                  href="#pricing"
                  class="inline-flex items-center justify-center rounded-lg border border-surface-border bg-surface px-5 py-2.5 font-semibold text-white transition hover:border-brand"
                >
                  Start free
                </a>
              </div>
            </div>
            <div class="overflow-hidden rounded-xl border border-surface-border bg-[#0a0d12]">
              <div class="flex items-center justify-between border-b border-surface-border px-4 py-3">
                <div class="flex items-center gap-2">
                  <span class="h-3 w-3 rounded-full bg-[#ff5f56]"></span>
                  <span class="h-3 w-3 rounded-full bg-[#ffbd2e]"></span>
                  <span class="h-3 w-3 rounded-full bg-[#27c93f]"></span>
                  <span class="ml-2 font-mono text-xs text-[#6e7681]">scan-pii.sh</span>
                </div>
                <span class="rounded bg-red-500/15 px-2 py-0.5 font-mono text-xs font-semibold text-red-400">BLOCK</span>
              </div>
              <pre class="overflow-x-auto p-5 font-mono text-xs leading-relaxed text-[#3fb950]"><code>{piiCurl}</code></pre>
              <div class="border-t border-surface-border"></div>
              <pre class="overflow-x-auto p-5 font-mono text-xs leading-relaxed text-[#8b949e]"><code>{piiResponse}</code></pre>
            </div>
          </div>
        </div>
      </section>

      <!-- FEATURES -->
      <section class="mx-auto max-w-6xl px-6 py-16">
        <h2 class="text-center text-3xl font-bold tracking-tight sm:text-4xl">26 tools. Six suites. One platform.</h2>
        <p class="mx-auto mt-3 max-w-2xl text-center text-[#8b949e]">
          Composable, agent-callable APIs that verify and improve LLM outputs before they cause damage.
          <span class="text-white">Click any tool for capabilities and use cases.</span>
        </p>
        <p class="mt-2 text-center text-xs font-semibold uppercase tracking-wider text-brand">Core quality checks</p>
        <div class="mt-6 grid grid-cols-1 gap-6 md:grid-cols-3">
          {
            features.map((t) => (
              <button type="button" data-modal={t.slug} class="group relative block w-full overflow-hidden rounded-xl border border-surface-border bg-surface-card p-6 text-left transition hover:border-brand/50 focus:outline-none focus-visible:ring-2 focus-visible:ring-brand">
                <div class="absolute inset-x-0 top-0 h-1 bg-brand"></div>
                <span class="flex h-11 w-11 items-center justify-center rounded-lg bg-brand/10 text-brand" set:html={icons[t.icon]} />
                <h3 class="mt-5 text-lg font-semibold">{t.title}</h3>
                <p class="mt-2 text-sm leading-relaxed text-[#8b949e]">{t.body}</p>
                <div class="mt-5 flex items-center justify-between">
                  <span class="inline-block rounded-md border border-surface-border bg-surface px-3 py-1.5 font-mono text-xs text-brand">{t.endpoint}</span>
                  <a href={`/tools/${t.slug}`} class="text-xs font-medium text-brand opacity-0 transition group-hover:opacity-100" onclick="event.stopPropagation()">More \u2192</a>
                </div>
              </button>
            ))
          }
        </div>

        <!-- Security, privacy & analysis tools -->
        <p class="mt-14 text-center text-xs font-semibold uppercase tracking-wider text-brand">Security, privacy &amp; analysis</p>
        <div class="mt-6 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {
            securityTools.map((t) => (
              <button type="button" data-modal={t.slug} class:list={["group relative block w-full overflow-hidden rounded-xl border bg-surface-card p-6 text-left transition focus:outline-none focus-visible:ring-2 focus-visible:ring-brand", t.featured ? "border-brand/50 ring-1 ring-brand/30" : "border-surface-border hover:border-brand/50"]}>
                <div class="absolute inset-x-0 top-0 h-1 bg-brand/50"></div>
                {t.featured && (
                  <span class="absolute right-3 top-3 rounded-full bg-brand/15 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wider text-brand">New</span>
                )}
                <span class="flex h-11 w-11 items-center justify-center rounded-lg bg-brand/10 text-brand" set:html={icons[t.icon]} />
                <h3 class="mt-5 text-base font-semibold">{t.title}</h3>
                <p class="mt-2 text-sm leading-relaxed text-[#8b949e]">{t.body}</p>
                <div class="mt-5 flex items-center justify-between">
                  <span class="inline-block rounded-md border border-surface-border bg-surface px-3 py-1.5 font-mono text-xs text-brand">{t.endpoint}</span>
                  <a href={`/tools/${t.slug}`} class="text-xs font-medium text-brand opacity-0 transition group-hover:opacity-100" onclick="event.stopPropagation()">More \u2192</a>
                </div>
              </button>
            ))
          }
        </div>

        <!-- Finance Protection tools -->
        <p class="mt-14 text-center text-xs font-semibold uppercase tracking-wider text-[#d29922]">Finance protection</p>
        <p class="mt-1 text-center text-xs text-[#6e7681]">Backed by real incidents: Lobstar $440k decimal error &middot; Claude Code $1,446 unauthorized sweep</p>
        <div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {
            financeTools.map((t) => (
              <button type="button" data-modal={t.slug} class="group relative block w-full overflow-hidden rounded-xl border border-[#9e6a03]/30 bg-surface-card p-5 text-left transition hover:border-[#d29922]/50 focus:outline-none focus-visible:ring-2 focus-visible:ring-[#d29922]">
                <div class="absolute inset-x-0 top-0 h-1 bg-[#d29922]/50"></div>
                <span class="flex h-9 w-9 items-center justify-center rounded-lg bg-[#d29922]/10 text-[#d29922]" set:html={icons[t.icon]} />
                <h3 class="mt-3 text-sm font-semibold">{t.title}</h3>
                <p class="mt-1.5 text-xs leading-relaxed text-[#8b949e]">{t.body}</p>
                <div class="mt-4 flex items-center justify-between">
                  <span class="inline-block rounded-md border border-[#9e6a03]/30 bg-surface px-2 py-1 font-mono text-[10px] text-[#d29922]">{t.endpoint}</span>
                  <a href={`/tools/${t.slug}`} class="text-[10px] font-medium text-[#d29922] opacity-0 transition group-hover:opacity-100" onclick="event.stopPropagation()">More \u2192</a>
                </div>
              </button>
            ))
          }
        </div>

        <!-- Compliance & safety tools -->
        <p class="mt-14 text-center text-xs font-semibold uppercase tracking-wider text-brand">Compliance &amp; safety</p>
        <p class="mt-1 text-center text-xs text-[#6e7681]">Deterministic, offline gates for regulated workflows &mdash; screen before you transact, dose before you advise</p>
        <div class="mt-6 grid grid-cols-1 gap-6 sm:grid-cols-2">
          {
            safetyTools.map((t) => (
              <button type="button" data-modal={t.slug} class="group relative block w-full overflow-hidden rounded-xl border border-brand/50 bg-surface-card p-6 text-left ring-1 ring-brand/30 transition hover:border-brand/60 focus:outline-none focus-visible:ring-2 focus-visible:ring-brand">
                <div class="absolute inset-x-0 top-0 h-1 bg-brand/60"></div>
                <span class="absolute right-3 top-3 rounded-full bg-brand/15 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wider text-brand">New</span>
                <span class="flex h-11 w-11 items-center justify-center rounded-lg bg-brand/10 text-brand" set:html={icons[t.icon]} />
                <h3 class="mt-5 text-base font-semibold">{t.title}</h3>
                <p class="mt-2 text-sm leading-relaxed text-[#8b949e]">{t.body}</p>
                <div class="mt-5 flex items-center justify-between">
                  <span class="inline-block rounded-md border border-surface-border bg-surface px-3 py-1.5 font-mono text-xs text-brand">{t.endpoint}</span>
                  <a href={`/tools/${t.slug}`} class="text-xs font-medium text-brand opacity-0 transition group-hover:opacity-100" onclick="event.stopPropagation()">More \u2192</a>
                </div>
              </button>
            ))
          }
        </div>

        <!-- Agent, infra & legal tools -->
        <p class="mt-14 text-center text-xs font-semibold uppercase tracking-wider text-brand">Agent, infra &amp; legal</p>
        <p class="mt-1 text-center text-xs text-[#6e7681]">Deterministic guardrails for tool calls, infrastructure changes, and legal work</p>
        <div class="mt-6 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {
            platformTools.map((t) => (
              <button type="button" data-modal={t.slug} class="group relative block w-full overflow-hidden rounded-xl border border-brand/40 bg-surface-card p-6 text-left transition hover:border-brand/60 focus:outline-none focus-visible:ring-2 focus-visible:ring-brand">
                <div class="absolute inset-x-0 top-0 h-1 bg-brand/60"></div>
                {t.featured && (
                  <span class="absolute right-3 top-3 rounded-full bg-brand/15 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wider text-brand">New</span>
                )}
                <span class="flex h-11 w-11 items-center justify-center rounded-lg bg-brand/10 text-brand" set:html={icons[t.icon]} />
                <h3 class="mt-5 text-base font-semibold">{t.title}</h3>
                <p class="mt-2 text-sm leading-relaxed text-[#8b949e]">{t.body}</p>
                <div class="mt-5 flex items-center justify-between">
                  <span class="inline-block rounded-md border border-surface-border bg-surface px-3 py-1.5 font-mono text-xs text-brand">{t.endpoint}</span>
                  <a href={`/tools/${t.slug}`} class="text-xs font-medium text-brand opacity-0 transition group-hover:opacity-100" onclick="event.stopPropagation()">More \u2192</a>
                </div>
              </button>
            ))
          }
        </div>

        <!-- Data & validation tools -->
        <p class="mt-14 text-center text-xs font-semibold uppercase tracking-wider text-brand">Data &amp; validation</p>
        <p class="mt-1 text-center text-xs text-[#6e7681]">Deterministic validators for identifiers, structured output, and SQL</p>
        <div class="mt-6 grid grid-cols-1 gap-6 sm:grid-cols-3">
          {
            dataTools.map((t) => (
              <button type="button" data-modal={t.slug} class="group relative block w-full overflow-hidden rounded-xl border border-brand/40 bg-surface-card p-6 text-left transition hover:border-brand/60 focus:outline-none focus-visible:ring-2 focus-visible:ring-brand">
                <div class="absolute inset-x-0 top-0 h-1 bg-brand/60"></div>
                {t.featured && (
                  <span class="absolute right-3 top-3 rounded-full bg-brand/15 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wider text-brand">New</span>
                )}
                <span class="flex h-11 w-11 items-center justify-center rounded-lg bg-brand/10 text-brand" set:html={icons[t.icon]} />
                <h3 class="mt-5 text-base font-semibold">{t.title}</h3>
                <p class="mt-2 text-sm leading-relaxed text-[#8b949e]">{t.body}</p>
                <div class="mt-5 flex items-center justify-between">
                  <span class="inline-block rounded-md border border-surface-border bg-surface px-3 py-1.5 font-mono text-xs text-brand">{t.endpoint}</span>
                  <a href={`/tools/${t.slug}`} class="text-xs font-medium text-brand opacity-0 transition group-hover:opacity-100" onclick="event.stopPropagation()">More \u2192</a>
                </div>
              </button>
            ))
          }
        </div>
      </section>

      <!-- CODE EXAMPLE -->
      <section id="code" class="mx-auto max-w-6xl px-6 py-16">
        <h2 class="text-center text-3xl font-bold tracking-tight sm:text-4xl">Catch it before it runs</h2>
