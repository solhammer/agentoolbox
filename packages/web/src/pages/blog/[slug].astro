---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await post.render();

const githubUrl = 'https://github.com/solhammer/agentoolbox';
const canonicalUrl = `https://agent-toolbox.ai/blog/${post.slug}`;
const formattedDate = post.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={post.data.description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
    <title>{post.data.title} — agent-toolbox.ai</title>
  </head>
  <body class="bg-surface text-white antialiased" style="font-family: 'Inter', system-ui, sans-serif;">
    <!-- NAV -->
    <header class="sticky top-0 z-40 border-b border-surface-border bg-surface/80 backdrop-blur">
      <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
        <a href="/" class="flex items-center gap-2 font-mono text-lg font-semibold tracking-tight">
          <span class="inline-block h-2.5 w-2.5 rounded-full bg-brand"></span>
          <span>agent-toolbox<span class="text-brand">.ai</span></span>
        </a>
        <div class="flex items-center gap-3">
          <a href="/#pricing" class="hidden text-sm font-medium text-[#8b949e] transition hover:text-white sm:inline">Pricing</a>
          <a href="/docs" class="hidden text-sm font-medium text-[#8b949e] transition hover:text-white sm:inline">Docs</a>
          <a href="/blog" class="hidden text-sm font-medium text-white sm:inline">Blog</a>
          <a
            href={githubUrl}
            class="inline-flex items-center gap-2 rounded-md border border-surface-border px-3 py-1.5 text-sm font-medium text-[#8b949e] transition hover:border-brand hover:text-white"
          >
            <svg viewBox="0 0 16 16" width="18" height="18" fill="currentColor" aria-hidden="true">
              <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"></path>
            </svg>
            GitHub
          </a>
        </div>
      </nav>
    </header>

    <main class="mx-auto max-w-3xl px-6 py-16">
      <!-- BREADCRUMB -->
      <nav class="mb-8 flex items-center gap-2 text-xs text-[#6e7681]">
        <a href="/" class="transition hover:text-white">Home</a>
        <span>/</span>
        <a href="/blog" class="transition hover:text-white">Blog</a>
        <span>/</span>
        <span class="text-[#8b949e]">{post.data.title}</span>
      </nav>

      <article>
        <header class="mb-10 border-b border-surface-border pb-8">
          <div class="flex flex-wrap items-center gap-3 text-xs text-[#6e7681]">
            <time datetime={post.data.date.toISOString()}>{formattedDate}</time>
            <span>·</span>
            <span>{post.data.author}</span>
            {post.data.tags.map((t) => (
              <span class="rounded-full border border-surface-border px-2 py-0.5 font-mono text-[#8b949e]">{t}</span>
            ))}
          </div>
          <h1 class="mt-3 text-4xl font-extrabold tracking-tight sm:text-5xl">{post.data.title}</h1>
          <p class="mt-4 text-lg text-[#8b949e]">{post.data.description}</p>
        </header>

        <div class="post">
          <Content />
        </div>
      </article>

      <div class="mt-12 border-t border-surface-border pt-8">
        <a href="/blog" class="inline-flex items-center gap-2 text-sm font-semibold text-brand transition hover:text-white">
          ← All posts
        </a>
      </div>
    </main>

    <!-- FOOTER -->
    <footer class="border-t border-surface-border mt-16">
      <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-4 px-6 py-8 text-sm text-[#8b949e] sm:flex-row">
        <div class="flex items-center gap-2 font-mono">
          <span class="inline-block h-2 w-2 rounded-full bg-brand"></span>
          <span>agent-toolbox.ai</span>
        </div>
        <span>Built for the agentic era</span>
        <a href={githubUrl} class="transition hover:text-white">GitHub</a>
      </div>
    </footer>

    <style is:global>
      .post {
        color: #c9d1d9;
        font-size: 1.05rem;
        line-height: 1.75;
      }
      .post > * + * {
        margin-top: 1.15rem;
      }
      .post h2 {
        color: #fff;
        font-size: 1.6rem;
        font-weight: 700;
        letter-spacing: -0.01em;
        margin-top: 2.5rem;
      }
      .post h3 {
        color: #fff;
        font-size: 1.2rem;
        font-weight: 600;
        margin-top: 1.75rem;
      }
      .post a {
        color: #00d4aa;
        text-decoration: underline;
        text-underline-offset: 2px;
      }
      .post a:hover {
        color: #7ee7d3;
      }
      .post strong {
        color: #fff;
        font-weight: 650;
      }
      .post ul {
        list-style: disc;
        padding-left: 1.4rem;
      }
      .post ol {
        list-style: decimal;
        padding-left: 1.4rem;
      }
      .post li {
        margin-top: 0.4rem;
      }
      .post li::marker {
        color: #00d4aa;
      }
      .post code {
        font-family: 'JetBrains Mono', 'Fira Code', monospace;
        font-size: 0.85em;
        background: #161b22;
        border: 1px solid #21262d;
        border-radius: 0.35rem;
        padding: 0.1rem 0.35rem;
        color: #00d4aa;
      }
      .post pre {
        border: 1px solid #21262d;
        border-radius: 0.6rem;
        padding: 1.1rem 1.25rem;
        overflow-x: auto;
        font-size: 0.85rem;
        line-height: 1.6;
      }
      .post pre code {
        background: transparent;
        border: none;
        padding: 0;
        color: inherit;
        font-size: inherit;
      }
      .post hr {
        border: 0;
        border-top: 1px solid #21262d;
        margin: 2.5rem 0;
      }
      .post blockquote {
        border-left: 3px solid #00d4aa;
        padding-left: 1rem;
        color: #8b949e;
      }
    </style>
  </body>
</html>
