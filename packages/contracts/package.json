{
  "name": "@agentoolbox/contracts",
  "version": "0.1.0",
  "private": true,
  "description": "Single source of truth: zod request/response schemas for every agent-toolbox endpoint, emitted as an OpenAPI 3.1 document that drives the API, the TS SDK, and the Python SDK.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": { ".": { "import": "./dist/index.js", "types": "./dist/index.d.ts" } },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "generate": "tsx src/generate.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.3.0",
    "openapi3-ts": "^4.6.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "tsx": "^4.19.0",
    "@types/node": "^22.0.0"
  }
}
